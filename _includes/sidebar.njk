<button class="nav-toggle" onclick="document.body.classList.toggle('nav-hidden')" aria-label="Toggle navigation"><span></span></button>
<nav class="sidebar">
  <div class="logo">{{ nav.project }}</div>

  <div class="nav-section">
    <h3>Pages</h3>
    {%- for p in nav.pages %}
    <a class="nav-link{% if page.url == p.url %} active{% endif %}" href="{{ p.url | url }}">{{ p.label }}</a>
    {%- endfor %}
  </div>

  <div class="nav-section">
    <h3>Foundational</h3>
    {%- for l in nav.lectures %}
      {%- if l.track == "Foundational" %}
    <a class="nav-link{% if page.url == '/' + l.id + '/' %} active{% endif %}" href="{{ ('/' + l.id + '/') | url }}">{{ l.id }}. {{ l.label }}</a>
      {%- endif %}
    {%- endfor %}
  </div>

  <div class="nav-section">
    <h3>ML / AI</h3>
    {%- for l in nav.lectures %}
      {%- if l.track == "ML/AI" %}
    <a class="nav-link{% if page.url == '/' + l.id + '/' %} active{% endif %}" href="{{ ('/' + l.id + '/') | url }}">{{ l.id }}. {{ l.label }}</a>
      {%- endif %}
    {%- endfor %}
  </div>

  <div class="nav-section">
    <h3>Applied</h3>
    {%- for l in nav.lectures %}
      {%- if l.track == "Applied" %}
    <a class="nav-link{% if page.url == '/' + l.id + '/' %} active{% endif %}" href="{{ ('/' + l.id + '/') | url }}">{{ l.id }}. {{ l.label }}</a>
      {%- endif %}
    {%- endfor %}
  </div>

  <div class="nav-section">
    <h3>Exercises</h3>
    {%- for e in nav.exercises %}
    <a class="nav-link" href="{{ e.url }}" target="_blank" rel="noopener">{{ e.id }}. {{ e.label }}</a>
    {%- endfor %}
  </div>

  <div class="nav-section">
    <h3>Resources</h3>
    {%- for r in nav.resources %}
    <a class="nav-link" href="{{ r.url }}" target="_blank" rel="noopener">{{ r.label }}</a>
    {%- endfor %}
  </div>
</nav>
